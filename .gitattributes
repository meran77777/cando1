# Normalize line endings: store everything as LF in the repo.
* text=auto eol=lf

*.go     text eol=lf
*.mod    text eol=lf
*.sum    text eol=lf
*.toml   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.sh     text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

*.png binary
*.jpg binary
